datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  weddings  Wedding[]
}

model Wedding {
  id                Int            @id @default(autoincrement())
  userId            Int
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug              String         @unique
  template          String         @default("RedWhite")
  
  // Groom Info
  groomName         String
  groomShortName    String?
  groomFather       String?
  groomMother       String?
  groomAddress      String?
  
  // Bride Info
  brideName         String
  brideShortName    String?
  brideFather       String?
  brideMother       String?
  brideAddress      String?
  
  // Wedding Date
  weddingDate       String
  
  // Event 1: Ceremony (Lễ Tân Hôn / Vu Quy)
  ceremonyTitle     String         @default("LỄ TÂN HÔN")
  ceremonyTime      String?
  ceremonyLocation  String?
  ceremonyMapIframe String?
  ceremonyMapLink   String?
  
  // Event 2: Party (Tiệc Cưới)
  partyTitle        String         @default("LỄ THÀNH HÔN")
  partyTime         String?
  partyLocation     String?
  partyMapIframe    String?
  partyMapLink      String?
  
  // Media & Settings
  musicUrl          String?
  albumPhotos       String         @default("[]") // Store JSON stringified array of URLs
  activeSections    String         @default("{\"music\":true,\"calendar\":true,\"maps\":true,\"rsvp\":true,\"gallery\":true,\"gift\":true}")
  
  // Bank Transfer
  bankName          String?
  bankAccount       String?
  bankHolderName    String?
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  rsvpResponses     RsvpResponse[]
}

model RsvpResponse {
  id               Int      @id @default(autoincrement())
  weddingId        Int
  wedding          Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  guestName        String
  relation         String?
  wishes           String?
  attendanceStatus String   @default("attending") // 'attending', 'absent', 'undecided'
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
